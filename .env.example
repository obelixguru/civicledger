# Supabase — public values, safe to commit when filled with placeholders.
# Get yours at https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Server-only secrets (do NOT prefix with NEXT_PUBLIC_)
# Used by /api routes for donation creation, proof validation, etc.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (donation checkout)
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Circle (EUR → EURC/USDC mint + transfer)
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=

# On-chain (smart contract release)
RPC_URL_POLYGON=https://polygon-rpc.com
RPC_URL_BASE=https://mainnet.base.org
RELAYER_PRIVATE_KEY=
